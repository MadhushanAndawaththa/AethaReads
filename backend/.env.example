# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=aetha
DB_PASSWORD=aetha_secret
DB_NAME=aetha_db
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# Cache TTL (seconds)
CHAPTER_CACHE_TTL=3600
NOVEL_CACHE_TTL=1800
CATALOG_CACHE_TTL=900

# Auth
JWT_SECRET=change-me-in-production-32chars!
ACCESS_TOKEN_EXPIRY_MIN=15
REFRESH_TOKEN_EXPIRY_DAYS=7
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
